# NextAuth 配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Supabase 配置
# 在 https://supabase.com/dashboard 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth
# 在 https://console.cloud.google.com/apis/credentials 创建
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# 在 https://github.com/settings/developers 创建
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# new-api 接入配置
# 指向你自己单独部署的官方 new-api 服务
ONE_API_URL=http://localhost:3001
ONE_API_KEY=sk-your-relay-key
ONE_API_ACCESS_TOKEN=your-access-token
ONE_API_USER_ID=1

# 团队邀请邮件（可选）
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=AI Gateway <noreply@example.com>
RESEND_REPLY_TO_EMAIL=support@example.com

# 官网联系信息与线索通知（可选）
CONTACT_EMAIL=contact@example.com
CONTACT_PHONE=+86 400-888-2048
CONTACT_ADDRESS=Beijing, China
CONTACT_LEADS_NOTIFY_EMAIL=sales@example.com
SALES_EMAIL=sales@example.com
SUPPORT_EMAIL=support@example.com
SUCCESS_EMAIL=success@example.com
CONTACT_SALES_NAME=Mike Zhang
CONTACT_SUPPORT_NAME=Lisa Li
CONTACT_SUCCESS_NAME=Fang Wang

# 官网分析（可选）
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# OpenRouter 模型目录（可选）
# 官网模型页优先读取 OpenRouter 全量模型；未配置时也会尝试匿名请求，失败则回退到本地目录
OPENROUTER_API_KEY=
OPENROUTER_MODELS_URL=https://openrouter.ai/api/v1/models
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=AI Gateway

# 手机号验证码（开发环境）
# 未接短信服务时，本地会返回 debugCode 用于联调
PHONE_AUTH_DEBUG_CODE=
