{
  "extends": "../../packages/shared-config/tsconfig.nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ai-gateway/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@ai-gateway/shared-types/*": [
        "../../packages/shared-types/src/*"
      ],
      "@ai-gateway/model-catalog": [
        "../../packages/model-catalog/catalog.json"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/shared-types/src/**/*.ts",
    "../../packages/model-catalog/catalog.json"
  ],
  "exclude": [
    "node_modules"
  ]
}
